# Copy this file to .env and fill in your values. .env is gitignored.
#   cp .env.example .env

# Your PS5's LAN IP address.
PS5RMTCTL_HOST=192.168.1.50

# Your PSN online-id (the account you registered with).
PS5RMTCTL_USER=your_psn_online_id

# API token clients must present (?token=... or "Authorization: Bearer ...").
# Generate one, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(24))"
PS5RMTCTL_TOKEN=generate-a-long-random-string

# Seconds of inactivity before the session is auto-released (0 = never).
PS5RMTCTL_IDLE_TIMEOUT=120
